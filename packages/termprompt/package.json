{
  "name": "termprompt",
  "version": "0.2.0",
  "type": "module",
  "description": "Beautiful terminal prompts with OSC 7770 structured output for rich terminal hosts",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "release": "pnpm test && pnpm typecheck && pnpm publish --access public"
  },
  "devDependencies": {
    "@termprompt/protocol": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/seeden/termprompt.git",
    "directory": "packages/termprompt"
  },
  "homepage": "https://seeden.github.io/termprompt/",
  "bugs": "https://github.com/seeden/termprompt/issues",
  "keywords": [
    "terminal",
    "prompt",
    "cli",
    "tui",
    "osc",
    "select",
    "confirm",
    "input",
    "interactive"
  ]
}
