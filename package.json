{
  "name": "termprompt",
  "version": "0.1.0",
  "type": "module",
  "description": "Beautiful terminal prompts with OSC 7770 structured output for rich terminal hosts",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "release": "pnpm test && pnpm typecheck && pnpm publish --access public"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "keywords": [
    "terminal",
    "prompt",
    "cli",
    "tui",
    "osc",
    "select",
    "confirm",
    "input",
    "interactive"
  ]
}
